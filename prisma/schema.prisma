generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mongodb"
  url      = "mongodb+srv://admin:admin@cluster0.scfpkji.mongodb.net/dwb?retryWrites=true&w=majority"
}

model Housings {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  adresse String
  city    String?
  name    String
  price   String
  size    String
  ownerId  String? @db.ObjectId
}

model User {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  birthday    String
  firstName   String
  name        String
  housingsId  String[] @db.ObjectId
}

model Rental {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  renterId    String @db.ObjectId
  housingId   String @db.ObjectId
  start_date  String
  end_date    String
}
