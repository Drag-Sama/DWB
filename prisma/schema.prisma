generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mongodb"
}

model Housings {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  adresse String
  city    String?
  id_     Int     @map("id")
  name    String
  /// Multiple data types found: String: 25%, BigInt: 75% out of 4 sampled entries
  price   Json
  /// Multiple data types found: String: 25%, Int: 75% out of 4 sampled entries
  size    Json
}
