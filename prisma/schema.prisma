generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mongodb"
}

model Housings {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  adresse String
  city    String?
  /// Multiple data types found: String: 16.7%, Int: 83.3% out of 6 sampled entries
  id_     Json    @map("id")
  name    String
  price   String?
  size    String?
}
