generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mongodb"
}

model Housings {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  adresse String
  city    String?
  id_     Int     @map("id")
  name    String
  price   BigInt
  size    Int
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}
